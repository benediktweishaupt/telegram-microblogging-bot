---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  date: Date;
  author: string;
  location?: { lat: number; lng: number; name: string };
  tags: string[];
  images: Array<{ src: ImageMetadata; width: number; height: number }>;
  body: string;
}

const { date, author, location, tags, images, body } = Astro.props;

const formattedDate = date.toLocaleDateString('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const hasImages = images.length > 0;
---

<article class="p-4">
  <div class="flex justify-between items-baseline py-2 text-neutral-800">
    {location && <span class="">{location.name}</span>}
    <span class="">{formattedDate}</span>
  </div>

  {
    hasImages ? (
      <div class="-mx-2">
        {images.map((img) => (
          <div class="aspect-[4/5] overflow-hidden rounded-md">
            <Image
              src={img.src}
              alt=""
              widths={[320, 640, 960]}
              sizes="(max-width: 470px) 100vw, 470px"
              loading="lazy"
              class="w-full h-full object-cover block"
            />
          </div>
        ))}
      </div>
    ) : body ? (
      <div class="-mx-2 bg-neutral-100 rounded-md px-8 py-6 font-serif text-xl leading-normal text-neutral-800 [&>p]:mb-1" set:html={body} />
    ) : null
  }

  {hasImages && body && <div class="pt-2.5 leading-relaxed text-neutral-800 [&>p]:mb-1" set:html={body} />}

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => <span class="text-gray-300">#{tag}</span>)}
    </div>
  )}
</article>
