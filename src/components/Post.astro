---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  date: Date;
  author: string;
  location?: { lat: number; lng: number; name: string };
  images: Array<{ src: ImageMetadata; width: number; height: number }>;
  body: string;
}

const { date, author, location, images, body } = Astro.props;

const formattedDate = date.toLocaleDateString('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="post">
  <div class="post-header">
    <span class="post-author">{author}</span>
    {location && <span class="post-location">{location.name}</span>}
  </div>

  {
    images.length > 0 && (
      <div
        class:list={[
          'post-images',
          { 'post-images--grid': images.length > 1 },
        ]}
      >
        {images.map((img, i) => (
          <Image
            src={img.src}
            alt=""
            widths={[320, 640, 960]}
            sizes="(max-width: 470px) 100vw, 470px"
            loading="lazy"
            class:list={[
              {
                'span-full':
                  images.length > 1 && images.length % 2 !== 0 && i === 0,
              },
            ]}
          />
        ))}
      </div>
    )
  }

  <div class="post-footer">
    {body && <div class="post-body" set:html={body} />}
    <span class="post-date">{formattedDate}</span>
  </div>
</article>

<style>
  .post {
    padding-bottom: 1.25rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid #efefef;
  }
  .post-header {
    padding: 0.5rem 0;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .post-author {
    font-size: 0.875rem;
    font-weight: 600;
    color: #262626;
  }
  .post-location {
    font-size: 0.75rem;
    color: #8e8e8e;
  }
  .post-location::before {
    content: '·';
    margin: 0 0.25rem;
    color: #8e8e8e;
  }
  .post-images {
    margin: 0 -1rem;
  }
  .post-images img {
    width: 100%;
    height: auto;
    display: block;
  }
  .post-images--grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2px;
  }
  .post-footer {
    padding-top: 0.625rem;
  }
  .post-body {
    font-size: 0.875rem;
    line-height: 1.4;
    color: #262626;
  }
  .post-body :global(p) {
    margin-bottom: 0.25em;
  }
  .post-date {
    display: block;
    font-size: 0.625rem;
    color: #8e8e8e;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-top: 0.375rem;
  }

  @media (min-width: 470px) {
    .post-images {
      margin: 0;
    }
    .post-images--grid {
      grid-template-columns: 1fr 1fr;
    }
    .span-full {
      grid-column: 1 / -1;
    }
  }
</style>
